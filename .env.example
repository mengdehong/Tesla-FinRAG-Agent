# Tesla FinRAG — environment variable template
# Copy to .env and fill in real values. Never commit .env.

# ── LLM provider ──────────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_BASE_URL=
# ── Vector / fact store ───────────────────────────────────────────────────────
LANCEDB_URI=data/processed/lancedb

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Retrieval tuning ──────────────────────────────────────────────────────────
RETRIEVAL_TOP_K=8
